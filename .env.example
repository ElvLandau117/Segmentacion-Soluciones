# =============================================================================
# .env.example  —  Plantilla de variables de entorno para el despliegue
#
# Copia este archivo a `.env` y ajusta los valores para tu entorno:
#     cp .env.example .env
#
# El `.env` real está en .gitignore y NO se sube al repo.
# El container y docker-compose leen estas variables al arrancar.
# =============================================================================

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

# Host en el que Gradio expone la app dentro del container.
# 0.0.0.0 = todas las interfaces (necesario para Docker). NO cambiar en prod.
APP_HOST=0.0.0.0

# Puerto interno de Gradio. Caddy hace reverse proxy a este puerto.
APP_PORT=7860

# Dominio publico que Caddy usa para obtener el certificado de Let's Encrypt.
# Truco gratis: usar nip.io con la IP del server con puntos -> guiones.
#   Ejemplo: si tu IP publica es 5.9.123.45, usa: 5-9-123-45.nip.io
# Con un dominio propio (recomendado a futuro): segmentacion.tu-dominio.com
DOMAIN=replace-me.nip.io


# -----------------------------------------------------------------------------
# Hugging Face Hub — gestión de pesos
# Ver docs/HUGGINGFACE_SETUP.md para el setup inicial.
# -----------------------------------------------------------------------------

# ID del repo en HF Hub que contiene los .pth. Formato: "usuario/repo".
# Ejemplo: HF_REPO_ID=elvis/spine-checkpoints
HF_REPO_ID=

# Token de lectura. SOLO necesario si HF_REPO_ID es un repo privado.
# Generar en https://huggingface.co/settings/tokens (tipo "read" es suficiente).
# Si el repo es público, déjalo vacío.
HF_TOKEN=

# Directorio donde el container cachea los .pth descargados de HF.
# Debe coincidir con el volumen montado en docker-compose.yml.
CHECKPOINTS_DIR=/data/checkpoints


# -----------------------------------------------------------------------------
# Modelos servidos (Ciclo 4: solo DeepLabV3+ — el ganador)
# -----------------------------------------------------------------------------

# Arquitectura del modelo multiclase a cargar.
# Debe ser una clave válida de MODEL_CONFIGS en spine_segmentation/config.py.
DEFAULT_MULTICLASS_MODEL=deeplabv3plus_resnet50

# Arquitectura del modelo binario (usado en tab Binary y cálculo de Cobb).
DEFAULT_BINARY_MODEL=unet_resnet50

# Nombres de los archivos .pth dentro del repo de HF Hub.
# Por convención: <model_name>_<task>_best.pth.
DEFAULT_MULTICLASS_WEIGHT=deeplabv3plus_resnet50_multiclass_best.pth
DEFAULT_BINARY_WEIGHT=unet_resnet50_binary_best.pth


# -----------------------------------------------------------------------------
# Inferencia
# -----------------------------------------------------------------------------

# Tamaño al que se redimensiona la imagen antes de pasarla al modelo.
# Coincide con el tamaño usado en entrenamiento (Ciclo 3 = 512).
# Bajarlo a 384 reduce latencia pero degrada Dice; NO recomendado.
INFERENCE_IMAGE_SIZE=512


# -----------------------------------------------------------------------------
# UI / disclaimer
# -----------------------------------------------------------------------------

# Texto del disclaimer médico que se muestra en la UI y en los reportes.
# Si quieres cambiar el wording sin tocar código, hazlo aquí.
MEDICAL_DISCLAIMER="This tool is for educational and research purposes only. It does NOT replace professional medical diagnosis. Always consult a qualified radiologist or specialist."
