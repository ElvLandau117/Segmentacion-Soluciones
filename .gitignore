# =============================================================================
# .gitignore — Spine Segmentation
# =============================================================================

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Entornos virtuales ---
.venv/
venv/
.env
.env.local
# El template .env.example SI va al repo (documenta los env vars disponibles)

# --- Dataset (pesado, propiedad U. Andes, se distribuye por separado) ---
MaIA_Scoliosis_Dataset/

# --- Pesos de modelos (distribuidos via Hugging Face Hub - ver README) ---
checkpoints/
checkpoints_inference/
paquete_equipo/

# --- Herramientas y configuracion local ---
.claude/
.vscode/
.idea/
*.swp

# --- MLflow runs (se regeneran al entrenar) ---
mlruns/

# --- Outputs generados (se regeneran al evaluar) ---
outputs/

# --- OS metadata ---
Thumbs.db
.DS_Store

# --- Jupyter ---
.ipynb_checkpoints/

# --- Notebook anterior del semestre anterior (referencia, no parte del proyecto) ---
notebooks/Laboratorio_sumativo_escoliosis_.ipynb
spine_model.keras
resnet50_weights_tf_dim_ordering_tf_kernels_notop.h5

# --- PDFs ---
# Por defecto los PDFs no se commitean (derechos de autor de libros y papers)
*.pdf
# EXCEPCION: los PDFs oficiales de la universidad SI van al repo
# (rubrica de evaluacion, parte del contrato academico)
!requisitos_universidad/*.pdf

# --- Transcripcion del curso de metodologia (derechos de autor) ---
docs/metodologia/orchestration_agentic_transcript.txt

# --- Archive (artefactos legacy, no se versionan) ---
# Toda la carpeta archive/ se ignora EXCEPTO su README explicativo
archive/*
!archive/README.md

# --- Hugging Face cache local ---
.cache/
.huggingface/

# --- Logs ---
*.log

# --- Documento final de entrega (se genera, no se versiona el binario) ---
Entrega_Final_Ciclo_4.pdf
Entrega_Final_Ciclo_4.docx
